# Copy to .env.local — never commit .env.local
# Get these from Supabase: Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public site URL — sitemap, canonical links, Paystack callbacks. Production: https://autosellgh.com
NEXT_PUBLIC_SITE_URL=https://autosellgh.com

# Optional analytics — same IDs as legacy static homepage (gtag.js + Facebook Pixel)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-LFJWGQR4RV
# NEXT_PUBLIC_FB_PIXEL_ID=768063732271819

# Paystack Ghana: set NEXT_PUBLIC_PAYSTACK_ENABLED=true and PAYSTACK_SECRET_KEY when ready.
# Dashboard → webhook → https://YOUR_DOMAIN/api/paystack/webhook
NEXT_PUBLIC_PAYSTACK_ENABLED=false
# PAYSTACK_SECRET_KEY=sk_live_...
# PAYSTACK_PREMIUM_AMOUNT_GHS=50
# PAYSTACK_COMPLETE_AMOUNT_GHS=200
# Comma-separated statuses that appear on the public site (browse + detail).
# Default if unset: completed. In the admin dashboard, set a submission to one of these when it should go live.
NEXT_PUBLIC_LISTING_STATUSES=completed

# Legacy demo imports (service role locally; NEVER expose key to client)
#   npm run legacy-sample-migrate — purge + seed 14 demos + uploads to Storage if web/public/Car Photos exists
#   npm run legacy-sample-seed — --purge to replace seeded rows only
#   npm run legacy-sample-upload-photos — push files to bucket car-photos/legacy-sample/… and PATCH photos on DB rows
# Optional: LEGACY_CAR_PHOTOS_ROOT=Absolute\path\to\folder\containing\Car Photos
# Optional seller fields: LEGACY_SEED_SELLER_NAME, LEGACY_SEED_SELLER_PHONE, LEGACY_SEED_SELLER_EMAIL

# DB: transmission/fuel — scripts/supabase-alter-transmission-fuel-status.sql
# DB: Paystack columns — scripts/supabase-paystack-columns.sql
# Keep rejected/archived out of NEXT_PUBLIC_LISTING_STATUSES for a public-only-live model.

NEXT_PUBLIC_WHATSAPP_E164=233505677556

# Server-only: page size for /cars pagination (default 12, clamped 4–100)
CARS_PAGE_SIZE=12

# Optional: integer column on car_submissions for SQL year filters (see scripts/supabase-year_numeric.sql)
# CAR_SUBMISSIONS_YEAR_COLUMN=year_numeric

# Server-only: service role key so public /sell submissions bypass RLS (Supabase → Settings → API → service_role)
# Without this, the form falls back to the browser client (must allow INSERT for anon in RLS policies).
SUPABASE_SERVICE_ROLE_KEY=

# Admin UI (/admin) — server-only; do not use NEXT_PUBLIC_ for the password
ADMIN_PASSWORD=change-me-strong-password
ADMIN_JWT_SECRET=use-a-long-random-string-for-signing-session-cookies
